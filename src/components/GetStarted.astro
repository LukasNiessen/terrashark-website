---
---

<section id="get-started" class="get-started-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Install the Terraform Skill</span>
      <h2>Get Started in <span class="text-gradient">30 Seconds</span></h2>
      <p>
        Three ways to install TerraShark — the Terraform &amp; OpenTofu skill for Claude Code and Codex.
      </p>
    </div>

    <!-- OS Filter -->
    <div class="os-filter">
      <button class="os-btn active" data-os="linux">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.868.074 1.741-.54 1.96-1.644l.01-.013c.104-.166.18-.396.2-.677.039-.531-.197-.964-.336-1.154-.202-.266-.396-.534-.461-.854-.104-.466-.196-1.004-.196-1.597a.737.737 0 00-.064-.27c.206-.598.146-1.15-.123-1.666-.397-.739-.975-1.206-1.413-1.706-.222-.248-.417-.526-.552-.869-.28-.707-.35-1.513-.395-2.293-.075-1.418.186-2.865.082-4.062-.104-1.22-.596-2.346-1.871-2.916A4.325 4.325 0 0012.504 0zm-.034 1.262c.382.001.758.057 1.123.187.89.393 1.207 1.199 1.29 2.2.088 1.065-.158 2.396-.092 3.885.05.87.126 1.783.462 2.636.191.479.445.835.724 1.14.449.51 1.003.925 1.345 1.556.165.303.215.614.08 1.005a.558.558 0 00-.023.18c0 .665.1 1.25.221 1.766.094.39.215.698.376.925a.88.88 0 01.144.46c-.015.21-.067.34-.124.424-.15.218-.396.39-.523.637-.127.239-.187.552-.187.912 0 .06-.003.12.005.177-.124.635-.554.897-1.016.858-.466-.04-.893-.39-1.145-.905a2.756 2.756 0 01-.087-.26c-.124-.48-.173-1.04-.267-1.484-.094-.44-.198-.779-.471-.941-.342-.202-.712-.18-1.097-.18-.287 0-.577.003-.862.023-.762.056-1.328.267-2.016.268h-.006c-.1 0-.18.036-.24.101a.556.556 0 00-.12.28 1.69 1.69 0 01-.638.625c-.484.13-1.24-.03-2.065-.453-1.036-.537-2.265-.43-2.9-.576-.316-.073-.503-.147-.59-.318-.088-.17-.074-.486.167-1.076a.887.887 0 00.075-.296c.013-.112-.012-.304-.06-.642-.03-.147-.055-.296-.055-.487 0-.143.03-.3.087-.46.543-1.556 1.698-3.126 2.524-4.107.867-1.093 1.166-2.162 1.247-3.341.068-1.065-.134-2.327-.134-3.55 0-.155.007-.31.019-.464a4.82 4.82 0 01.413-1.711 2.89 2.89 0 011.157-1.252 3.31 3.31 0 011.66-.468z"/></svg>
        Linux
      </button>
      <button class="os-btn" data-os="macos">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        macOS
      </button>
      <button class="os-btn" data-os="windows">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
        Windows
      </button>
    </div>

    <div class="install-stack">
      <!-- Option 1: Clone -->
      <div class="install-card card">
        <div class="install-badge">Recommended</div>
        <div class="install-card-inner">
          <div class="install-info">
            <h3>Option 1: Clone to Skills Directory</h3>
            <p>Auto-discovered by Claude Code on every session. No restart needed.</p>
          </div>
          <div class="install-commands">
            <!-- Linux -->
            <div class="code-block os-content" data-os="linux">
              <div class="code-header">
                <span class="code-lang">bash</span>
                <button class="copy-btn" data-copy="git clone https://github.com/LukasNiessen/terrashark.git ~/.claude/skills/terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git \
  ~/.claude/skills/terrashark</code></pre>
            </div>
            <!-- macOS -->
            <div class="code-block os-content" data-os="macos">
              <div class="code-header">
                <span class="code-lang">bash</span>
                <button class="copy-btn" data-copy="git clone https://github.com/LukasNiessen/terrashark.git ~/.claude/skills/terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git \
  ~/.claude/skills/terrashark</code></pre>
            </div>
            <!-- Windows -->
            <div class="code-block os-content" data-os="windows">
              <div class="code-header">
                <span class="code-lang">powershell</span>
                <button class="copy-btn" data-copy='git clone https://github.com/LukasNiessen/terrashark.git "$env:USERPROFILE\.claude\skills\terrashark"' aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git `
  "$env:USERPROFILE\.claude\skills\terrashark"</code></pre>
            </div>
          </div>
        </div>
      </div>

      <!-- Option 2: Marketplace -->
      <div class="install-card card">
        <div class="install-card-inner">
          <div class="install-info">
            <h3>Option 2: Marketplace (Claude Code)</h3>
            <p>Use the built-in plugin marketplace. Add the repo, then install. Or use the interactive plugin manager with <code>/plugin</code> and the Discover tab.</p>
          </div>
          <div class="install-commands">
            <div class="code-block os-content-all">
              <div class="code-header">
                <span class="code-lang">claude code</span>
                <button class="copy-btn" data-copy="/plugin marketplace add LukasNiessen/terrashark
/plugin install terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>/plugin marketplace add LukasNiessen/terrashark
/plugin install terrashark</code></pre>
            </div>
          </div>
        </div>
      </div>

      <!-- Option 3: Codex -->
      <div class="install-card card">
        <div class="install-card-inner">
          <div class="install-info">
            <h3>Option 3: OpenAI Codex</h3>
            <p>Codex has no global skill system. Clone into your project root, then reference it from your <code>AGENTS.md</code>.</p>
          </div>
          <div class="install-commands">
            <!-- Linux -->
            <div class="code-block os-content" data-os="linux">
              <div class="code-header">
                <span class="code-lang">bash</span>
                <button class="copy-btn" data-copy="git clone https://github.com/LukasNiessen/terrashark.git .terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git .terrashark</code></pre>
            </div>
            <!-- macOS -->
            <div class="code-block os-content" data-os="macos">
              <div class="code-header">
                <span class="code-lang">bash</span>
                <button class="copy-btn" data-copy="git clone https://github.com/LukasNiessen/terrashark.git .terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git .terrashark</code></pre>
            </div>
            <!-- Windows -->
            <div class="code-block os-content" data-os="windows">
              <div class="code-header">
                <span class="code-lang">powershell</span>
                <button class="copy-btn" data-copy="git clone https://github.com/LukasNiessen/terrashark.git .terrashark" aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>git clone https://github.com/LukasNiessen/terrashark.git .terrashark</code></pre>
            </div>
            <!-- AGENTS.md snippet (always shown) -->
            <div class="code-block os-content-all" style="margin-top: 0.75rem;">
              <div class="code-header">
                <span class="code-lang">AGENTS.md</span>
                <button class="copy-btn" data-copy="## Terraform

When working with Terraform or OpenTofu, follow the workflow in `.terrashark/SKILL.md`.
Load references from `.terrashark/references/` as needed." aria-label="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
              <pre><code>## Terraform

When working with Terraform or OpenTofu, follow the workflow
in `.terrashark/SKILL.md`.
Load references from `.terrashark/references/` as needed.</code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="usage-note">
      <p>
        Once installed, just ask any Terraform or OpenTofu question naturally.
        TerraShark activates automatically — or invoke it explicitly:
      </p>
      <div class="code-block code-block-inline">
        <pre><code><span class="t-dim">$</span> <span class="t-accent">claude</span> "/terrashark Create a multi-region S3 module with replication"</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .get-started-section {
    background: var(--color-bg-alt);
  }

  /* OS Filter Tabs */
  .os-filter {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .os-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-dim);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition);
  }

  .os-btn:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-text);
  }

  .os-btn.active {
    background: var(--color-accent-glow);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Stacked install cards */
  .install-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .install-card {
    position: relative;
  }

  .install-badge {
    position: absolute;
    top: -0.5rem;
    right: 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    z-index: 1;
  }

  .install-card-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .install-info h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }

  .install-info p {
    font-size: 0.88rem;
    max-width: none;
  }

  .install-commands {
    display: flex;
    flex-direction: column;
  }

  /* Code blocks */
  .code-block {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .code-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0, 0, 0, 0.2);
  }

  .code-lang {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--color-text-dim);
    cursor: pointer;
    padding: 2px;
    transition: color var(--transition);
  }

  .copy-btn:hover {
    color: var(--color-accent);
  }

  .code-block pre {
    margin: 0;
    padding: 0.75rem;
    overflow-x: auto;
  }

  .code-block code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.6;
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
    word-break: break-all;
    white-space: pre-wrap;
  }

  /* OS visibility */
  .os-content {
    display: none;
  }

  .os-content.visible {
    display: block;
  }

  .os-content-all {
    display: block;
  }

  /* Usage note */
  .usage-note {
    text-align: center;
    margin-top: 3rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .usage-note p {
    margin: 0 auto 1rem;
    font-size: 0.95rem;
    max-width: none;
  }

  .code-block-inline {
    display: inline-block;
    max-width: 100%;
  }

  .t-dim { color: var(--color-text-dim); }
  .t-accent { color: var(--color-accent); }

  @media (max-width: 600px) {
    .os-filter {
      gap: 0.35rem;
    }

    .os-btn {
      padding: 0.5rem 0.85rem;
      font-size: 0.8rem;
    }

    .os-btn svg {
      display: none;
    }
  }
</style>

<script>
  // OS tab switching
  const osBtns = document.querySelectorAll('.os-btn');
  const osBlocks = document.querySelectorAll('.os-content');

  function setOS(os: string) {
    osBtns.forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.os === os);
    });
    osBlocks.forEach((block) => {
      block.classList.toggle('visible', (block as HTMLElement).dataset.os === os);
    });
  }

  // Auto-detect OS
  function detectOS(): string {
    const ua = navigator.userAgent.toLowerCase();
    if (ua.includes('win')) return 'windows';
    if (ua.includes('mac')) return 'macos';
    return 'linux';
  }

  osBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const os = (btn as HTMLElement).dataset.os;
      if (os) setOS(os);
    });
  });

  // Initialize with detected OS
  setOS(detectOS());

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          const original = btn.innerHTML;
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00e5c8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => {
            btn.innerHTML = original;
          }, 2000);
        });
      }
    });
  });
</script>
