---
const modes = [
  {
    number: '01',
    name: 'Identity Churn',
    color: '#00e5c8',
    description: 'Resource addressing instability during refactors. Prevents destroy/create cycles with proper for_each usage and moved blocks.',
    details: ['count vs for_each decision matrix', 'Safe migration playbooks', 'Index-based identity detection'],
  },
  {
    number: '02',
    name: 'Secret Exposure',
    color: '#ff6b6b',
    description: 'Secrets leaking through state, logs, defaults, and artifacts. Ensures secrets stay out of version control and plan outputs.',
    details: ['sensitive vs write_only guidance', 'External secret manager patterns', 'Rotation playbooks'],
  },
  {
    number: '03',
    name: 'Blast Radius',
    color: '#febc2e',
    description: 'Oversized stacks with weak boundaries. Enforces proper ownership, change cadence, and recovery boundaries.',
    details: ['Boundary model enforcement', 'Environment separation', 'State isolation rules'],
  },
  {
    number: '04',
    name: 'CI Drift',
    color: '#7c5cfc',
    description: 'Version mismatches, unreviewed applies, and missing artifacts across your delivery pipeline.',
    details: ['GitHub Actions templates', 'GitLab CI templates', 'Drift prevention baseline'],
  },
  {
    number: '05',
    name: 'Compliance Gaps',
    color: '#4ecdc4',
    description: 'Missing policies, approvals, and audit controls for frameworks like SOC 2, ISO 27001, FedRAMP, and HIPAA.',
    details: ['Framework-specific gate mappings', 'Policy-as-code patterns', 'Risk-classed approval models'],
  },
];
---

<section id="failure-modes" class="failure-modes-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">5 Terraform Failure Modes</span>
      <h2>Every Terraform Pitfall, <span class="text-gradient">Diagnosed & Fixed</span></h2>
      <p>
        TerraShark identifies which failure modes apply to your task, then loads only the relevant
        guardrails. No wasted tokens, no missed risks.
      </p>
    </div>

    <div class="modes-list">
      {modes.map((mode) => (
        <div class="mode-card card">
          <div class="mode-header">
            <span class="mode-number" style={`color: ${mode.color};`}>{mode.number}</span>
            <h3 class="mode-name">{mode.name}</h3>
          </div>
          <p class="mode-description">{mode.description}</p>
          <ul class="mode-details">
            {mode.details.map((detail) => (
              <li>
                <span class="mode-check" style={`color: ${mode.color};`}>&#x2713;</span>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .failure-modes-section {
    background: var(--color-bg-alt);
  }

  .modes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mode-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 2rem;
    align-items: start;
  }

  .mode-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    grid-column: 1 / -1;
    margin-bottom: 0.75rem;
  }

  .mode-number {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    opacity: 0.6;
  }

  .mode-name {
    font-size: 1.2rem;
    margin-bottom: 0;
  }

  .mode-description {
    grid-column: 1 / 3;
    font-size: 0.95rem;
    max-width: none;
  }

  .mode-details {
    grid-column: 3;
    grid-row: 2;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .mode-details li {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .mode-check {
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .mode-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .mode-details {
      margin-top: 0.5rem;
    }

    .mode-details li {
      white-space: normal;
    }
  }
</style>
