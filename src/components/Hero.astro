---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <div class="animate-in">
          <span class="section-label">The #1 Terraform Skill for AI Coding Assistants</span>
        </div>

        <h1 class="animate-in delay-1">
          The Terraform Skill That<br/>
          <span class="hero-typed-line">
            Prevents <span class="typewriter-wrapper"><span id="typewriter" class="text-gradient"></span><span class="cursor" id="cursor">|</span></span>
          </span>
        </h1>

        <p class="hero-subtitle animate-in delay-2">
          TerraShark is the open-source Terraform &amp; OpenTofu skill for Claude Code.
          It diagnoses failure modes <em>before</em> generating code &mdash; eliminating hallucinations,
          secret exposure, identity churn, and blast-radius mistakes from your infrastructure.
        </p>

        <div class="hero-actions animate-in delay-3">
          <a href="#get-started" class="btn btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="https://github.com/LukasNiessen/terrashark"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>

        <div class="hero-stats animate-in delay-4">
          <div class="stat">
            <span class="stat-value">7x</span>
            <span class="stat-label">More Token-Efficient</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">5</span>
            <span class="stat-label">Failure Modes Covered</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">18</span>
            <span class="stat-label">Reference Modules</span>
          </div>
        </div>
      </div>

      <div class="hero-visual animate-in delay-3">
        <div class="terminal">
          <div class="terminal-bar">
            <span class="terminal-dot" style="background: #ff5f57;"></span>
            <span class="terminal-dot" style="background: #febc2e;"></span>
            <span class="terminal-dot" style="background: #28c840;"></span>
            <span class="terminal-title">terraform plan</span>
          </div>
          <div class="terminal-body">
            <code>
              <span class="t-dim">$</span> <span class="t-accent">claude</span> "Create a multi-region S3 module"<br/><br/>
              <span class="t-dim">&#x276F;</span> <span class="t-purple">TerraShark</span> activated<br/>
              <span class="t-dim">&#x276F;</span> Diagnosing failure modes...<br/>
              <span class="t-dim">&nbsp;&nbsp;</span> <span class="t-warn">&#x26A0;</span> Identity churn — <span class="t-accent">for_each</span> required<br/>
              <span class="t-dim">&nbsp;&nbsp;</span> <span class="t-warn">&#x26A0;</span> Secret exposure — encryption keys<br/>
              <span class="t-dim">&nbsp;&nbsp;</span> <span class="t-ok">&#x2713;</span> Blast radius — properly scoped<br/>
              <span class="t-dim">&#x276F;</span> Generating with guardrails...<br/><br/>
              <span class="t-ok">&#x2713;</span> <span class="t-bright">Plan complete</span> — 0 hallucinations
            </code>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative gradient orbs -->
  <div class="hero-orb hero-orb-1"></div>
  <div class="hero-orb hero-orb-2"></div>
</section>

<style>
  .hero {
    padding-top: calc(var(--section-pad) + 4rem);
    padding-bottom: var(--section-pad);
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-top: 1.5rem;
    max-width: 540px;
  }

  .hero-typed-line {
    display: inline;
  }

  .typewriter-wrapper {
    display: inline;
    position: relative;
  }

  #typewriter {
    display: inline;
  }

  .cursor {
    display: inline;
    font-weight: 300;
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .stat-value {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }

  /* Terminal */
  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow:
      0 0 60px rgba(0, 229, 200, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  .terminal-body {
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .terminal-body code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .t-dim { color: var(--color-text-dim); }
  .t-accent { color: var(--color-accent); }
  .t-purple { color: var(--color-secondary); }
  .t-warn { color: #febc2e; }
  .t-ok { color: #28c840; }
  .t-bright { color: var(--color-text-bright); }

  /* Orbs */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-orb-1 {
    width: 500px;
    height: 500px;
    background: rgba(0, 229, 200, 0.08);
    top: -100px;
    left: -150px;
  }

  .hero-orb-2 {
    width: 400px;
    height: 400px;
    background: rgba(124, 92, 252, 0.08);
    bottom: -100px;
    right: -100px;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-visual {
      max-width: 500px;
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .stat-divider {
      display: none;
    }
  }
</style>

<script>
  const words = [
    'Hallucinations',
    'Identity Churn',
    'Secret Exposure',
    'Blast-Radius Mistakes',
    'CI Drift',
    'Compliance Gaps',
  ];

  const el = document.getElementById('typewriter');
  if (el) {
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let timeout: ReturnType<typeof setTimeout>;

    function tick() {
      const currentWord = words[wordIndex];

      if (isDeleting) {
        charIndex--;
        el.textContent = currentWord.substring(0, charIndex);

        if (charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          timeout = setTimeout(tick, 400);
          return;
        }
        timeout = setTimeout(tick, 40);
      } else {
        charIndex++;
        el.textContent = currentWord.substring(0, charIndex);

        if (charIndex === currentWord.length) {
          isDeleting = true;
          timeout = setTimeout(tick, 2200);
          return;
        }
        timeout = setTimeout(tick, 70);
      }
    }

    // Start after a brief delay
    setTimeout(tick, 800);
  }
</script>
