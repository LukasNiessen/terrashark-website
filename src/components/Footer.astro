<footer class="footer">
  <div class="container">
    <div class="footer-cta">
      <h2>Stop Terraform Hallucinations <span class="text-gradient">Today</span></h2>
      <p>
        Join developers using the most advanced Terraform skill for AI-assisted infrastructure.
        Open source. MIT licensed. Free forever.
      </p>
      <div class="footer-actions">
        <a
          href="https://github.com/LukasNiessen/terrashark"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Get TerraShark on GitHub
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-brand">
        <span>&#x1F988;</span>
        Terra<span class="text-accent">Shark</span>
      </div>
      <p class="footer-tagline">The #1 Terraform &amp; OpenTofu Skill for AI Coding Assistants</p>
      <div class="footer-links">
        <a href="https://github.com/LukasNiessen/terrashark" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span class="footer-sep">&middot;</span>
        <a href="https://github.com/LukasNiessen/terrashark/issues" target="_blank" rel="noopener noreferrer">Issues</a>
        <span class="footer-sep">&middot;</span>
        <a href="https://github.com/LukasNiessen/terrashark/discussions" target="_blank" rel="noopener noreferrer">Discussions</a>
        <span class="footer-sep">&middot;</span>
        <span class="footer-copy">MIT License</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--section-pad) 0 2rem;
    position: relative;
  }

  .footer-cta {
    text-align: center;
    padding: 3.5rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--gradient-card);
    margin-bottom: 3rem;
    position: relative;
    overflow: hidden;
  }

  .footer-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
  }

  .footer-cta h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.75rem;
  }

  .footer-cta p {
    margin: 0 auto 1.5rem;
    font-size: 1rem;
    max-width: 50ch;
  }

  .footer-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text-bright);
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-size: 0.85rem;
    margin-bottom: 1rem;
    max-width: none;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-sep {
    color: var(--color-border);
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }
</style>
